# ═══════════════════════════════════════════════════════════════════════════════
# LAPLACE'S DEMON — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# WARNING: Never commit .env or any file containing real keys to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Execution Engine (Rust) ───────────────────────────────────────────────
# Ethereum vault address (the smart contract that holds funds)
VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# Chain ID (1 = Ethereum Mainnet, 5 = Goerli, 11155111 = Sepolia)
CHAIN_ID=1

# RPC endpoint (use your own node or a trusted provider)
RPC_URL=http://localhost:8545

# Gas price in wei (default: 42 gwei)
GAS_PRICE=42000000000

# Comma-separated MEV relay URLs (Flashbots, Builder0x69, BeaverBuild, etc.)
MEV_RELAYS=https://relay.flashbots.net,https://builder0x69.io

# Flashbots searcher key (ECDSA private key, 32 bytes hex-encoded)
SEARCHER_KEY=

# Executor hot wallets — at least one required (max 8)
PRIVATE_KEY_1=
PRIVATE_KEY_2=
PRIVATE_KEY_3=
PRIVATE_KEY_4=

# ── CEX Emergency API Keys (Watchdog) ────────────────────────────────────
# Used only for Cancel All Orders + Market Close on emergency stop.
# Withdrawal permission MUST be disabled on all exchanges.
BINANCE_API_KEY=
BINANCE_SECRET=
OKX_API_KEY=
OKX_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=
COINBASE_API_KEY=
COINBASE_SECRET=

# ── Network Defense ──────────────────────────────────────────────────────
# WireGuard peer configuration (RPC node endpoint)
WG_ENDPOINT=203.0.113.10:51820
WG_PEER_PUBKEY=<rpc-node-wireguard-public-key>
